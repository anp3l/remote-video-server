# ============================================
#  VIDEO SERVER - ENVIRONMENT CONFIGURATION
# ============================================

# === SERVER CONFIGURATION ===
NODE_ENV=development
PORT=3001

# Enable detailed video processing logs
ENABLE_LOGS=false

# === DATABASE ===
# MongoDB connection string - update with your database name and credentials
MONGO_URI=mongodb://localhost:27017/videoLibrary

# === JWT VERIFICATION ===
# Base64-encoded public key for verifying user identity tokens from Auth Server
# This should match the PUBLIC_KEY from your auth-server
PUBLIC_KEY_BASE64=your-base64-encoded-public-key

# === VIDEO STREAMING ===
# Secret key for STREAM token signing - generate a secure random string
STREAM_SECRET=your-very-secret-key

# === SECURITY ===
# CORS - Allowed origins (comma-separated, no spaces)
# Must include your frontend URL
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Cookie Security (for HttpOnly authentication cookies)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false  # true in production (requires HTTPS)
COOKIE_SAMESITE=lax  # strict, lax, or none

# CSRF Protection
CSRF_SECRET=your-super-secret-csrf-key-change-this-in-production